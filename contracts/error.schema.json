{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "configx error envelope",
  "type": "object",
  "required": ["kind", "op", "message", "retryable"],
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "auth",
        "already_exists",
        "canceled",
        "config",
        "conflict",
        "connection",
        "internal",
        "not_found",
        "rate_limit",
        "timeout",
        "unavailable",
        "validation"
      ]
    },
    "op": { "type": "string" },
    "message": { "type": "string" },
    "retryable": { "type": "boolean" }
  },
  "additionalProperties": false
}

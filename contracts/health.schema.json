{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Health Status",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "status", "checked_at"],
  "properties": {
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["healthy", "degraded", "unhealthy"]
    },
    "message": {
      "type": "string"
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "latency_ms": {
      "type": "integer",
      "minimum": 0
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
